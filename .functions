#-----------------------------------------------------------------------------------#
#       Git
#-----------------------------------------------------------------------------------#
bigbang() {
  if [[ -z "$1" ]]; then
    echo "Errore: URL del repository obbligatorio. Uso: bigbang https://url-del-repository/"
    return 1
  fi

  git init
  git add . 
  git commit -m '💥 Big Bang'
  git remote add origin "$1" 
  git branch -M main
  git push -u origin main
}

#-----------------------------------------------------------------------------------#
#       Flutter
#-----------------------------------------------------------------------------------#

flutterCrashAndroid() {
    version=$(awk '/^version: /{print $2}' ./pubspec.yaml)
    if [ -z "$version" ]; then
        echo "Error: Version is blank."
        return 1
    fi

    androidAppId=$(grep mobilesdk_app_id ./android/app/google-services.json | tail -n1 | sed 's/.*\"mobilesdk_app_id\": \"\(.*\)\",/\1/')
    firebase crashlytics:symbols:upload --app="$androidAppId" debug-info/android/$version
}

#-----------------------------------------------------------------------------------#
#       MySQL and databases
#-----------------------------------------------------------------------------------#

mycreate() {
    if [ "$1" != "" ]
    then
        mysql -u root -e "create database $1"
    else
        print "Database name required, ex.: $0 <database>"
    fi
}

mylist() {
    mysql -u root -e "show databases"
}

mydrop() {
    if [ "$1" != "" ]
    then
        mysql -u root -e "drop database $1"
    else
        print "Database name required, ex.: $0 <database>"
    fi
}

#-----------------------------------------------------------------------------------#
#       Utils
#-----------------------------------------------------------------------------------#
mfdread() {
    xxd "$1" | awk 'NR%4==0 {print "\033[0;31m" $0 "\033[0m"; next} {print}'
}

#-----------------------------------------------------------------------------------#
#	AI
#-----------------------------------------------------------------------------------#
init-claude-memory() {
  echo -n "Nome del progetto: "
  read PROGETTO
  mkdir -p .claude/commands
  echo "Usa il server MCP \"Memory-Keeper\" e salva la conversazione corrente nella categoria \"$PROGETTO\" con il titolo \"{{param1}}\"." > .claude/commands/salva.md
  echo "Usa il server MCP \"Memory-Keeper\" e lista solo i titoli delle funzionalità salvate nella categoria \"$PROGETTO\", in elenco puntato:" > .claude/commands/memoria.md
  echo "Usa il server MCP \"Memory-Keeper\" e cancella dalla categoria \"$PROGETTO\" la funzionalità \"{{param1}}\"." > .claude/commands/dimentica.md
  echo "Usa il server MCP \"Memory-Keeper\" e appendi alla funzionalità \"{{param1}}\" nella categoria \"$PROGETTO\" la conversazione corrente." > .claude/commands/continua.md
  echo "Comandi Claude creati per il progetto $PROGETTO"
}

cdx() {
  if [[ "$1" == "update" ]]; then
    npm install -g @openai/codex@latest
  else
    codex --model 'gpt-5-codex' --full-auto -c model_reasoning_summary_format=experimental --search "$@"
  fi
}

#-----------------------------------------------------------------------------------#
#	Directory utilities
#-----------------------------------------------------------------------------------#
mkd() {
    mkdir -p "$@" && cd "$_"
}

#-----------------------------------------------------------------------------------#
#	Git utilities
#-----------------------------------------------------------------------------------#
git-prune-local() {
    git fetch --prune
    git branch -vv | grep ': gone]' | awk '{print $1}' | xargs git branch -D
}

clone() {
    gh repo clone "$1" && cd "$(basename "$1")"
}

#-----------------------------------------------------------------------------------#
#	Laravel / Pest
#-----------------------------------------------------------------------------------#
p() {
    if [ -f vendor/bin/pest ]; then
        vendor/bin/pest "$@"
    else
        php artisan test "$@"
    fi
}

pf() {
    p --filter "$@"
}

scheduler() {
    while true; do
        php artisan schedule:run
        sleep 60
    done
}

#-----------------------------------------------------------------------------------#
#	AI commit message
#-----------------------------------------------------------------------------------#
commit() {
    local message
    message=$(git diff --cached | claude -p "Write a concise git commit message for these changes. No markdown, plain text only, max 72 chars.")
    git commit -m "$message"
}

claude-yolo() {
    claude --dangerously-skip-permissions "$@"
}
