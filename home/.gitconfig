[user]
    name = Luca
    email = # inserire la tua email
    signingkey = # inserire la chiave SSH da 1Password

[gpg]
    format = ssh

[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
    gpgsign = true

[core]
    autocrlf = false
    pager = delta
    excludesfile = ~/.global-gitignore

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pull]
    rebase = false

[fetch]
    prune = true

[init]
    defaultBranch = main
