#!/bin/bash
#
# Sets up PHP for all Homebrew-installed versions:
# - Installs PECL extensions
# - Configures xdebug for PhpStorm
# - Restarts Valet
#
# Usage: setup-php [--disable-xdebug]

set -e

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step() { echo ""; echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

if [[ "$(/usr/bin/uname -m)" == "arm64" ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"
else
    HOMEBREW_PREFIX="/usr/local"
fi

PHP_BASE="$HOMEBREW_PREFIX/etc/php"

if [ ! -d "$PHP_BASE" ]; then
    echo "No PHP versions found at $PHP_BASE"
    exit 1
fi

DISABLE_XDEBUG=false
if [[ "$1" == "--disable-xdebug" ]]; then
    DISABLE_XDEBUG=true
fi

# PECL extensions
step "Installing PECL extensions..."
pecl install imagick 2>/dev/null || warn "imagick already installed or failed"
pecl install memcached 2>/dev/null || warn "memcached already installed or failed"
pecl install xdebug 2>/dev/null || warn "xdebug already installed or failed"
pecl install redis 2>/dev/null || warn "redis already installed or failed"
success "PECL extensions processed"

# xdebug config for each PHP version
step "Configuring xdebug for all PHP versions..."

for version_dir in "$PHP_BASE"/*/; do
    version=$(basename "$version_dir")
    CONF_DIR="$PHP_BASE/$version/conf.d"
    INI_FILE="$CONF_DIR/ext-xdebug.ini"

    if [ ! -d "$CONF_DIR" ]; then
        warn "conf.d not found for PHP $version, skipping"
        continue
    fi

    if [ "$DISABLE_XDEBUG" = true ]; then
        if [ -f "$INI_FILE" ]; then
            rm "$INI_FILE"
            success "PHP $version: xdebug disabled"
        else
            warn "PHP $version: nothing to disable"
        fi
        continue
    fi

    cat > "$INI_FILE" <<EOF
[xdebug]
xdebug.mode = debug
xdebug.start_with_request = yes
xdebug.client_host = 127.0.0.1
xdebug.client_port = 9003
xdebug.idekey = PHPSTORM
xdebug.log_level = 0
EOF

    success "PHP $version: xdebug configured"
done

# Restart Valet
if command -v valet &> /dev/null; then
    step "Restarting Valet..."
    valet restart
    success "Valet restarted"
fi

echo ""
success "PHP setup complete!"
